"Formula":{"JSExt":0,"Interpreter":1,"Expression":"const navDistance = Math.round($prop('GameRawData.NavigationValues.NavigationDistance')/1000);\r\nconst navTimeRaw = $prop('GameRawData.NavigationValues.NavigationTimeSeconds');\r\nconst navTimeFormatted = toHHMMSS(navTimeRaw);\r\n\r\nif (!$prop('variable.job')) return 'Freeroaming';\r\nreturn navDistance + ' km - ' + navTimeFormatted","PreExpression":"function toHHMMSS (timeRaw) {\r\n    var sec_num = parseInt(timeRaw, 10); \r\n    var hours   = Math.floor(sec_num / 3600);\r\n    var minutes = Math.floor((sec_num - (hours * 3600)) / 60);\r\n    var seconds = sec_num - (hours * 3600) - (minutes * 60);\r\n    \r\n    if (hours < 1) return minutes + ' min';\r\n    \r\n    if (minutes < 10) {minutes = \"0\" + minutes;}\r\n    return hours + 'h' + minutes\r\n}\r\n"},"Mode":2}}},{"$type":"SimHub.Plugins.OutputPlugins.GraphicalDash.Models.ImageItem, SimHub.Plugins","Image":"pin_white","AutoSize":false,"BackgroundColor":"#00FFFFFF","Height":20.0,"Left":45.0,"Top":15.0,"Visible":true,"BlinkDelay":1000.0,"BlinkPhasisInverted":false,"Width":20.0,"Name":"TripPinImage","RenderingSkip":0,"MinimumRefreshIntervalMS":0.0}],"Visible":true,"BlinkPhasisInverted":false,"Name":"Trip","RenderingSkip":0,"MinimumRefreshIntervalMS":0.0},{"$type":"SimHub.Plugins.OutputPlugins.GraphicalDash.Models.RectangleItem, SimHub.Plugins","IsRectangleItem":true,"BackgroundColor":"#0BFFFFFF","BorderStyle":{"BorderColor":"#22FFFFFF","BorderTop":2,"BorderBottom":2,"BorderLeft":2,"BorderRight":2,"RadiusTopLeft":8,"RadiusTopRight":8,"RadiusBottomLeft":8,"RadiusBottomRight":8},"Height":50.0,"Left":0.0,"Top":0.0,"Visible":true,"BlinkPhasisInverted":false,"Width":600.0,"IsFreezed":true,"Name":"RectangleItem","RenderingSkip":0,"MinimumRefreshIntervalMS":0.0}],"MinimumRefreshIntervalMS":0.0}],"SnapToGrid":true,"HideLabels":false,"ShowForeground":true,"ForegroundOpacity":100.0,"ShowBackground":true,"BackgroundOpacity":100.0,"ShowBoundingRectangles":true,"GridSize"