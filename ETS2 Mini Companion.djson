{"Variables":{"DashboardVariables":[{"VariableName":"isOverSpeedLimit","EvaluateOnlyOnce":false,"OverrideWithParentDashboardVariableWhenAvailable":true,"ValueExpression":{"JSExt":0,"Interpreter":1,"Expression":"if ($prop('variable.speedLimitLocalUnit') == 0) return false;\r\nif ($prop('SpeedLocal') > speedLimit) return true;\r\nreturn false;"},"EvaluateBeforeScreenRoles":false},{"VariableName":"speedLimitLocalUnit","EvaluateOnlyOnce":false,"OverrideWithParentDashboardVariableWhenAvailable":true,"ValueExpression":{"JSExt":0,"Interpreter":1,"Expression":"return $prop('SpeedLocalUnit') === \"KMH\" ? $prop('GameRawData.NavigationValues.SpeedLimit.Kph') : $prop('GameRawData.NavigationValues.SpeedLimit.Mph');"},"EvaluateBeforeScreenRoles":false},{"VariableName":"speedCurrentLimitDelta","EvaluateOnlyOnce":false,"OverrideWithParentDashboardVariableWhenAvailable":true,"ValueExpression":{"JSExt":0,"Interpreter":1,"Expression":"return $prop('SpeedLocal') - $prop('variable.speedLimitLocalUnit')"},"EvaluateBeforeScreenRoles":false},{"VariableName":"cruiseControlToggled","EvaluateOnlyOnce":false,"OverrideWithParentDashboardVariableWhenAvailable":true,"ValueExpression":{"JSExt":0,"Interpreter":1,"Expression":"return $prop('GameRawData.TruckValues.CurrentValues.DashboardValues.CruiseControl')"},"EvaluateBeforeScreenRoles":false},{"VariableName":"isCruiseControlOverSpeedLimit","EvaluateOnlyOnce":false,"OverrideWithParentDashboardVariableWhenAvailable":true,"ValueExpression":{"JSExt":0,"Interpreter":1,"Expression":"if (!$prop('variable.cruiseControlToggled')) return false;\r\nif ($prop('variable.isSpeedLimitEnforced')) return false;\r\nif ($prop('GameRawData.TruckValues.CurrentValues.DashboardValues.CruiseControlSpeed.Value') > $prop('variable.speedLimitLocalUnit')) return true;\r\nreturn false;"},"EvaluateBeforeScreenRoles":false},{"VariableName":"isSpeedLimitEnforced","EvaluateOnlyOnce":false,"OverrideWithParentDashboardVariableWhenAvailable":true,"ValueExpression":{"JSExt":0,"Inte